{
  "name": "invoice-management",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate",
    "db:push": "pnpm --filter @invoice/database db:push",
    "db:migrate": "pnpm --filter @invoice/database db:migrate",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.4.0"
  }
}
